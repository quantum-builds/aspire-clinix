generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ReferralForm {
  id                          String           @id @default(cuid())
  createdAt                   DateTime         @default(now())
  treatmentDetails            String?
  other                       String?
  referralEmail               String
  referralGDC                 String
  referralName                String
  medicalHistoryPdfUrl        String?
  patientAddress              String
  patientDateOfBirth          DateTime
  patientEmail                String
  patientId                   String?
  patientName                 String
  patientPhoneNumber          String
  referralDentistId           String?
  attendTreatment             String
  referralPracticeNameAddress String
  cbct                        String?
  dentalSpecialty             String?
  practiceEmail               String?
  practiceName                String?
  practicePhoneNumber         String?
  cbctReportPdfUrl            String?
  prescriptionDetails         String?
  patient                     Patient?         @relation(fields: [patientId], references: [id])
  referralDentist             Dentist?         @relation(fields: [referralDentistId], references: [id])
  referralRequest             ReferralRequest?

  @@index([patientEmail])
}

model ReferralRequest {
  id                String                @id @default(cuid())
  referralFormId    String                @unique
  assignedDentistId String?
  appointmentId     String?               @unique
  requestStatus     ReferralRequestStatus
  createdAt         DateTime              @default(now())
  referralForm      ReferralForm          @relation(fields: [referralFormId], references: [id])


}

model Plan {
  id                 String                @id @default(uuid())
  name               String
  description        String
  price              Float
  validity           Int
  includedTreatments String[]
  discountId         String?
  status             PlanStatus            @default(ACTIVE)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  discounts          Discount?             @relation(fields: [discountId], references: [id])
  users              UserSubscribedPlans[]
}
model Discount {
  id        String       @id @default(uuid())
  type      DiscountType
  value     Float
  expiresAt DateTime
  plans     Plan[]
}

model UserSubscribedPlans {
  userId       String
  planId       String
  subscribedAt DateTime
  plans        Plan     @relation(fields: [planId], references: [id])

  @@unique([userId, planId])
}



model Dentist {
  id                  String              @id @default(cuid())
  email               String              @unique
  gdcNo               String              @unique
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  otp                 String?
  otpInvalidationTime DateTime?
  firstName           String
  lastName            String
  appointmentIds      String[]
  role                DentistRole         @default(REFERRING_DENTIST)
  dentallyId          Int?
  fileUrl             String?
  practices           DentistOnPractice[]
  referralForms       ReferralForm[]
  reports             Report[]
}

model Patient {
  id                  String         @id @default(cuid())
  uuid                String         @unique
  mobileNumber        String
  dateOfBirth         String
  otp                 String?
  otpInvalidationTime DateTime?
  email               String
  familyId            String?
  appointmentIds      String[]
  name                String         @unique
  dentallyId          Int            @unique
  imageUrl            String?
  referralForms       ReferralForm[]
  reports             Report[]

  @@index([familyId])
}

model Admin {
  id          String   @id @default(cuid())
  fullName    String
  email       String   @unique
  phoneNumber String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  password    String
  fileUrl     String?
}

model Practice {
  id           String              @id @default(cuid())
  email        String              @unique
  name         String              @unique
  phoneNumber  String              @unique
  postcode     String
  timeZone     String
  town         String
  nhs          Boolean             @default(false)
  openingHours Json
  addressLine1 String
  addressLine2 String
  logoUrl      String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  dentists     DentistOnPractice[]
}

model DentistOnPractice {
  practiceId String
  dentistId  String
  status     PracticeApprovalStatus @default(PENDING)
  dentist    Dentist                @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  practice   Practice               @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@id([practiceId, dentistId])
}

model AppointmentRequests {
  id            String                   @id @default(cuid())
  requestedDate DateTime
  reason        String
  note          String?
  fileUrl       String?
  updatedAt     DateTime                 @updatedAt
  patientId     String
  createdAt     DateTime                 @default(now())
  status        AppointmentRequestStatus @default(PENDING)
  appointmentId String?                  @unique
}

model Report {
  id                String           @id @default(cuid())
  dentistId         String
  title             String
  fileUrl           String
  fileType          ResoucrceType
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  appointmentId     String
  patientDentallyId String
  patientId         String?
  recipientType     ReportRecipient?
  dentist           Dentist          @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  patient           Patient?         @relation(fields: [patientId], references: [id])

  @@index([appointmentId])
  @@index([patientDentallyId])
  @@index([fileType])
}

model Resource {
  id        String        @id @default(cuid())
  title     String
  fileUrl   String
  fileType  ResoucrceType
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([fileType])
}

model Product {
  id                String             @id @default(cuid())
  name              String             @unique
  price             Float
  stock             Int
  ratings           Float
  imageUrl          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  productId         String             @unique
  cartProducts      CartProduct[]
  purchasedProducts PurchasedProduct[]
}

model Cart {
  id           String        @id @default(cuid())
  patientId    String        @unique
  cartProducts CartProduct[]
}

model CartProduct {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  Cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model PurchasedProduct {
  id               String         @id @default(cuid())
  patientId        String
  productId        String
  productPaymentId String
  purchaseDate     DateTime       @default(now())
  quantity         Int
  itemId           String
  product          Product        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  payment          ProductPayment @relation(fields: [productPaymentId], references: [id])

  @@unique([productPaymentId, productId])
  @@index([patientId, productId])
}

model ProductPayment {
  id            String             @id @default(cuid())
  patientId     String
  email         String
  paymentIntent String
  amount        Float
  status        PaymentStatus      @default(PENDING)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  products      PurchasedProduct[]

  @@unique([email, paymentIntent])
}

model Video {
  id          String @id @default(cuid())
  dentistId   String
  patientId   String
  fileContent String
  fileName    String
  fileType    String
}

enum InvoiceStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum PlanStatus {
  ACTIVE
  EXPIRED
  UPCOMING
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PatientTreatmentStatus {
  SCHEDULED
  PENDING
  RESCHEDULED
  ONGOING
  COMPLETED
  CANCELED
  NO_SHOW
  FAILED
  EXPIRED
}

enum ResoucrceType {
  VIDEO
  PDF
  IMAGES
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
  REFUND_PENDING
  REFUND_FAILED
}

enum DentistRole {
  DENTIST
  RECIEVING_DENTIST
  REFERRING_DENTIST
  DENTALLY_PRACTITIONER
}

enum GenderType {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ARRIVED
  IN_SURGERY
  COMPLETED
  CANCELLED
  DID_NOT_ATTEND
}

enum AppointmentRequestStatus {
  APPROVED
  PENDING
  CANCEL
}

enum UserRoles {
  ADMIN
  PATIENT
  DENTIST
}

enum PracticeApprovalStatus {
  PENDING
  APPROVED
  CANCELLED
}

enum ReferralRequestStatus {
  ASSIGNED
  UNASSIGNED
}

enum ReportRecipient {
  PATIENT
  REFERRING_DENTIST
}
